# Required — included in every request User-Agent per SEC fair-access policy
# https://www.sec.gov/os/accessing-edgar-data
SEC_CONTACT_EMAIL=your_email@example.com

# Optional — how many calendar days back to scan (default: 2)
DAYS_BACK=2

# Optional — filings to process per run, max 40 (EFTS page size limit)
PAGE_SIZE=40
