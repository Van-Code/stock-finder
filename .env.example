# Required — included in every request User-Agent per SEC fair-access policy
# https://www.sec.gov/os/accessing-edgar-data
SEC_CONTACT_EMAIL=your_email@example.com

# Optional — how many calendar days back to scan Form 4s (default: 2)
DAYS_BACK=2

# Optional — how many calendar days back to scan 13D/13G activist filings (default: 7)
ACTIVIST_DAYS_BACK=7

# Optional — filings to process per run, max 40 (EFTS page size limit)
PAGE_SIZE=40

# Optional — set to false to skip Yahoo Finance 90-day price checks
FETCH_PRICE_DATA=true
